# Copy to .env and fill in values before running docker-compose.

# Rotating residential proxy — REQUIRED for production (carrier anti-bot blocks DC IPs)
# Get one from: BrightData, Oxylabs, Smartproxy, NetNut
# Format: http://username:password@gate.example.com:7777
PROXY_URL=

# Set to "false" to run Chrome headed (useful for local debugging)
HEADLESS=true

# Add delay (ms) between Playwright actions — helps with very aggressive rate-limit (0=off)
SLOW_MO=0

# Comma-separated allowed CORS origins in production
# ALLOWED_ORIGINS=https://yourapp.example.com

# Allstate — Akamai persistent profile
# 1. Run once locally:  cd backend && python save_allstate_session.py
# 2. docker-compose mounts this dir into the container automatically
ALLSTATE_PROFILE_DIR=~/.allstate-chrome-profile
# CDP dev mode (optional — Chrome must be running with --remote-debugging-port=9222)
# ALLSTATE_CDP_URL=http://localhost:9222
